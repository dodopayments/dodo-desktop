{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Dodo Payments",
  "version": "0.1.2",
  "identifier": "com.dodopayments.desktop",
  "build": {
    "frontendDist": "https://app.dodopayments.com"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' https://app.dodopayments.com; connect-src 'self' https://*.dodopayments.com https://dodopayments.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data: https:; frame-src https://app.dodopayments.com; object-src 'none'; base-uri 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["dodopayments"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZEQjEzQUI3QjY5NjZFRjUKUldUMWJwYTJ0enF4YlE5Zldla0ZkMTdjMWIya1FsSlZrQnZDM2xQdDVZU2p2TExpTWZZb2c0TTIK",
      "endpoints": [
        "https://github.com/dodopayments/dodo-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "category": "Finance",
    "publisher": "Dodo Payments Inc.",
    "shortDescription": "Dodo Payments Desktop App",
    "longDescription": "Desktop application for Dodo Payments - manage payments, subscriptions, and disputes.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.acs.microsoft.com",
      "signCommand": "trusted-signing-cli -e https://eus.codesigning.azure.net -a dodopayments -c dodo-public-trust %1",
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
